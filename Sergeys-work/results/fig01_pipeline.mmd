flowchart LR
    subgraph Scene ["Scene inputs"]
        R["object velocity<br/>object size<br/>background clutter"]
    end

    subgraph Workload ["Sensor workload"]
        E["DVS event rate<br/>events / second<br/>the scene triggers"]
        F["CIS frame rate<br/>fps needed to catch<br/>the motion without blur"]
    end

    subgraph Specs ["Datasheet specs"]
        DB["4 DVS + 4 CIS sensors<br/>static power, event energy,<br/>max fps, ADC bits"]
    end

    subgraph Power ["Per-sensor power"]
        DP["DVS power<br/>always-on floor<br/>plus energy per event"]
        CP["CIS power<br/>scales with the<br/>required frame rate"]
    end

    subgraph Analyt ["Analytical power study"]
        SA["power vs velocity curves<br/>for every CIS and DVS"]
    end

    subgraph Bench ["Tracking benchmark"]
        NM["sensor simulators<br/>DVS events and CIS frames<br/>optional motion coasting"]
        ST["multi-object tracker<br/>HOTA, MOTA, IDF1 scores"]
        SB["run on MOT17 pedestrian video<br/>and on synthetic scenes"]
    end

    subgraph Out ["Figures in the deck"]
        F1["Sensor rundown table"]
        F2["Power vs velocity crossover"]
        F4["Tracking accuracy vs power<br/>on MOT17"]
        F5["Effect of motion coasting<br/>on DVS tracking"]
        F7["Real MOT17 video vs<br/>synthetic scenes"]
    end

    R --> E
    R --> F
    DB --> DP
    DB --> CP
    DB --> F1
    E --> DP
    F --> CP
    DP --> SA
    CP --> SA
    R --> NM
    DP --> SB
    CP --> SB
    NM --> ST
    ST --> SB
    SA --> F2
    SB --> F4
    SB --> F5
    SB --> F7

    %% --- Color palette -----------------------------------------------------
    %% One color per pipeline stage. Nodes get a strong fill, the surrounding
    %% subgraph gets a lighter wash of the same hue so the stage reads at a
    %% glance without drowning the arrows.

    classDef scene    fill:#cfe9cf,stroke:#2d6a2d,color:#10240f,stroke-width:1.5px
    classDef workload fill:#ffe9a8,stroke:#b07c00,color:#3b2a00,stroke-width:1.5px
    classDef specs    fill:#dcdcdc,stroke:#555555,color:#1c1c1c,stroke-width:1.5px
    classDef power    fill:#dccef5,stroke:#5f3dc4,color:#1a0e3d,stroke-width:1.5px
    classDef analyt   fill:#cce0fb,stroke:#1c54a6,color:#0a1f40,stroke-width:1.5px
    classDef bench    fill:#f7c9c1,stroke:#a02d1c,color:#3b0f0a,stroke-width:1.5px
    classDef out      fill:#ffd97a,stroke:#ac6f00,color:#2e1e00,stroke-width:2px

    class R scene
    class E,F workload
    class DB specs
    class DP,CP power
    class SA analyt
    class NM,ST,SB bench
    class F1,F2,F4,F5,F7 out

    style Scene    fill:#ecfaec,stroke:#2d6a2d,color:#10240f
    style Workload fill:#fff6d6,stroke:#b07c00,color:#3b2a00
    style Specs    fill:#f2f2f2,stroke:#555555,color:#1c1c1c
    style Power    fill:#efeafc,stroke:#5f3dc4,color:#1a0e3d
    style Analyt   fill:#e6efff,stroke:#1c54a6,color:#0a1f40
    style Bench    fill:#fde5df,stroke:#a02d1c,color:#3b0f0a
    style Out      fill:#fff0c5,stroke:#ac6f00,color:#2e1e00